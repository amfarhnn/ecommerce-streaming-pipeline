  <diagram id="event-processing-flow" name="Event Processing Flow">
    <mxGraphModel dx="1500" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1000" background="#ffffff" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="flow-title" value="Runtime Event Processing Flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=26;fontStyle=1;fontColor=#0F172A;" vertex="1" parent="1">
          <mxGeometry x="0" y="30" width="1800" height="50" as="geometry" />
        </mxCell>
        <mxCell id="step1" value="1. Generate event&#xa;uuid event_id&#xa;random user + product&#xa;event_type in page_view, add_to_cart, purchase&#xa;price 20 to 3000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="140" width="250" height="170" as="geometry" />
        </mxCell>
        <mxCell id="step2" value="2. Publish event&#xa;KafkaProducer sends JSON bytes&#xa;Topic: ecommerce-events&#xa;Broker: redpanda:9092" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#7E22CE;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="140" width="250" height="170" as="geometry" />
        </mxCell>
        <mxCell id="step3" value="3. Consume event&#xa;KafkaConsumer subscribes to topic&#xa;Group: ecommerce-consumer-group&#xa;JSON deserializer restores dict" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEDD5;strokeColor=#EA580C;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="690" y="140" width="250" height="170" as="geometry" />
        </mxCell>
        <mxCell id="step4" value="4. Transform event&#xa;Add high_value flag&#xa;1 when price &gt;= 1000&#xa;0 when price &lt; 1000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF9C3;strokeColor=#CA8A04;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1000" y="140" width="250" height="170" as="geometry" />
        </mxCell>
        <mxCell id="step5" value="5. Persist event&#xa;create_events_table() on startup&#xa;insert_event() writes to events&#xa;ON CONFLICT event_id DO NOTHING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#1D4ED8;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1310" y="140" width="280" height="170" as="geometry" />
        </mxCell>
        <mxCell id="decision" value="Was event inserted and event_type == purchase?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;strokeWidth=2;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="735" y="420" width="230" height="140" as="geometry" />
        </mxCell>
        <mxCell id="purchase-yes" value="Yes&#xa;update_product_sales_summary()&#xa;Insert product row or increment total_purchases&#xa;Add price to total_revenue" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEF2FF;strokeColor=#4F46E5;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1060" y="410" width="300" height="160" as="geometry" />
        </mxCell>
        <mxCell id="purchase-no" value="No&#xa;Keep raw event only&#xa;No product summary update&#xa;Prevents duplicate replay inflation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#64748B;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="420" y="410" width="260" height="160" as="geometry" />
        </mxCell>
        <mxCell id="analytics-step" value="Analytics and export&#xa;analytics.py reads PostgreSQL&#xa;export_analytics.py creates CSV files&#xa;check_db.py validates latest rows and summary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#15803D;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="690" width="360" height="150" as="geometry" />
        </mxCell>
        <mxCell id="flow-edge-1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#334155;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="step1" target="step2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="flow-edge-2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#334155;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="step2" target="step3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="flow-edge-3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#334155;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="step3" target="step4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="flow-edge-4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#334155;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="step4" target="step5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="flow-edge-5" value="rowcount == 1?" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#D97706;strokeWidth=2;fontSize=11;endArrow=classic;" edge="1" parent="1" source="step5" target="decision">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="flow-edge-yes" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4F46E5;strokeWidth=2;fontSize=11;endArrow=classic;" edge="1" parent="1" source="decision" target="purchase-yes">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="flow-edge-no" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#64748B;strokeWidth=2;fontSize=11;endArrow=classic;" edge="1" parent="1" source="decision" target="purchase-no">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="flow-edge-analytics-1" value="query" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#15803D;strokeWidth=2;fontSize=11;endArrow=classic;" edge="1" parent="1" source="purchase-yes" target="analytics-step">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="flow-edge-analytics-2" value="query" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#15803D;strokeWidth=2;fontSize=11;endArrow=classic;" edge="1" parent="1" source="purchase-no" target="analytics-step">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="deployment-operations" name="Deployment and Operations">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1000" background="#ffffff" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="ops-title" value="Deployment and Operations View" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=26;fontStyle=1;fontColor=#0F172A;" vertex="1" parent="1">
          <mxGeometry x="0" y="30" width="1800" height="50" as="geometry" />
        </mxCell>
        <mxCell id="ops-compose" value="docker compose up --build&#xa;Builds Python image from Dockerfile&#xa;Starts infrastructure and app services&#xa;Uses health-gated dependencies" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#1D4ED8;strokeWidth=2;fontSize=13;fontStyle=1;align=left;verticalAlign=top;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="140" width="330" height="160" as="geometry" />
        </mxCell>
        <mxCell id="ops-redpanda-health" value="Redpanda readiness&#xa;Command: rpk cluster health&#xa;-X brokers=localhost:9092&#xa;start_period=30s&#xa;producer waits for healthy Redpanda&#xa;consumer waits for healthy Redpanda" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#7E22CE;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="510" y="130" width="330" height="180" as="geometry" />
        </mxCell>
        <mxCell id="ops-postgres-health" value="PostgreSQL readiness&#xa;Image: postgres:16&#xa;Command: pg_isready&#xa;Volume: postgres_data&#xa;Host port: 5433&#xa;Container port: 5432&#xa;consumer waits for healthy PostgreSQL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#1D4ED8;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="940" y="130" width="330" height="190" as="geometry" />
        </mxCell>
        <mxCell id="ops-env" value="Runtime configuration&#xa;Host analytics: 127.0.0.1:5433&#xa;Docker consumer: postgres:5432&#xa;Docker Kafka broker: redpanda:9092&#xa;Host Kafka broker for local producer: 127.0.0.1:9092" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2E8F0;strokeColor=#334155;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1370" y="130" width="340" height="190" as="geometry" />
        </mxCell>
        <mxCell id="ops-app-image" value="Python application image&#xa;Base: python:3.11-slim&#xa;Installs requirements.txt&#xa;Includes producer, consumer, DB adapter, analytics scripts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="420" width="330" height="150" as="geometry" />
        </mxCell>
        <mxCell id="ops-producer-command" value="producer service&#xa;command: python src/producer.py&#xa;depends_on redpanda healthy&#xa;KAFKA_BROKER=redpanda:9092" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
