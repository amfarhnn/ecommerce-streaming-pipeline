        <mxCell id="power-bi" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacing=10;labelBackgroundColor=none;" value="Power BI / BI Tool&#xa;Event distribution&#xa;Revenue by product&#xa;Top purchases&#xa;Recent events" vertex="1">
