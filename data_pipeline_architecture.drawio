          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-redpanda-topic" edge="1" parent="1" source="redpanda" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;fontSize=11;endArrow=classic;labelBackgroundColor=none;fontColor=default;" target="topic" value="stores message stream">
