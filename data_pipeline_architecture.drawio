        <mxCell id="producer" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontStyle=1;fontSize=12;align=left;verticalAlign=top;spacing=10;labelBackgroundColor=none;" value="producer container&#xa;python src/producer.py&#xa;Faker data generator&#xa;Event every 2 seconds&#xa;JSON serializer" vertex="1">
          <mxGeometry height="160" width="260" x="470" y="210" as="geometry" />
