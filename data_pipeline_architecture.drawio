        <mxCell id="redpanda" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontStyle=1;fontSize=12;align=left;verticalAlign=top;spacing=10;labelBackgroundColor=none;" value="redpanda container&#xa;redpandadata/redpanda:latest&#xa;Kafka API listener: 9092&#xa;Advertised as redpanda:9092&#xa;Healthcheck: rpk cluster health" vertex="1">
