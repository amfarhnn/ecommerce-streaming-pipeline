          <mxGeometry height="170" width="250" x="1148" y="680" as="geometry" />
        </mxCell>
        <mxCell id="summary-table" parent="1" style="shape=table;startSize=28;container=1;collapsible=0;childLayout=tableLayout;fixedRows=1;rowLines=0;fontStyle=1;align=center;resizeLast=1;html=1;strokeWidth=2;fontSize=12;labelBackgroundColor=none;" value="product_sales_summary&#xa;product PK&#xa;total_purchases&#xa;total_revenue&#xa;Updated only for purchase events" vertex="1">
          <mxGeometry height="150" width="250" x="1450" y="660" as="geometry" />
        </mxCell>
        <mxCell id="volume" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=12;align=center;verticalAlign=middle;spacing=8;labelBackgroundColor=none;" value="postgres_data volume&#xa;Persistent database storage&#xa;/var/lib/postgresql/data" vertex="1">
          <mxGeometry height="90" width="290" x="800" y="880" as="geometry" />
        </mxCell>
        <mxCell id="analytics-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacing=10;labelBackgroundColor=none;" value="Analytics layer&#xa;query_dataframe()&#xa;analytics.py prints reports&#xa;export_analytics.py writes CSV files" vertex="1">
          <mxGeometry height="120" width="330" x="1160" y="927" as="geometry" />
        </mxCell>
        <mxCell id="edge-compose-producer" edge="1" parent="1" source="docker-compose-file" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;fontSize=11;endArrow=classic;labelBackgroundColor=none;fontColor=default;" target="producer" value="builds + starts">
