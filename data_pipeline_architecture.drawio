        </mxCell>
        <mxCell id="consumer" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontStyle=1;fontSize=12;align=left;verticalAlign=top;spacing=10;labelBackgroundColor=none;" value="consumer container&#xa;python src/consumer.py&#xa;Reads topic messages&#xa;Deserializes JSON&#xa;Logs to logs/streaming_pipeline.log" vertex="1">
          <mxGeometry height="160" width="270" x="1160" y="210" as="geometry" />
        </mxCell>
        <mxCell id="transform" parent="1" style="rounded=1;whiteSpace=wrap;html=1;strokeWidth=2;fontSize=12;align=left;verticalAlign=top;spacing=10;labelBackgroundColor=none;" value="Transform + reliability logic&#xa;high_value = 1 when price &gt;= 1000&#xa;3 database write retries&#xa;Insert event idempotently&#xa;Update summary only if insert is new" vertex="1">
          <mxGeometry height="160" width="270" x="1160" y="410" as="geometry" />
        </mxCell>
